TZ=Asia/Shanghai

WEB_PORT=80

RUSTFS_ROOT_ACCESS_KEY=change-me-rustfs-root-access-key
RUSTFS_ROOT_SECRET_KEY=change-me-rustfs-root-secret-key
RUSTFS_ACCESS_KEY_ID=change-me-rustfs-system-access-key
RUSTFS_SECRET_ACCESS_KEY=change-me-rustfs-system-secret-key
RUSTFS_CONSOLE_ENABLE=true
RUSTFS_CONSOLE_CORS_ALLOWED_ORIGINS=*
RUSTFS_BUCKET=xiaosongshu
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001

KKFILEVIEW_PORT=8018
KKFILE_OA_BASE_URL=http://xiaosongshu-nginx
KKFILEVIEW_PUBLIC_URL=

NODE_ENV=production
NODE_IMAGE=node:22-bookworm-slim
PORT=5175
BODY_LIMIT_BYTES=3145728000
DB_PATH=data/xiaosongshu.sqlite
DEFAULT_CURRENT_USER=本地用户
UPLOAD_MAX_FILE_SIZE_MB=3000
FILE_PROXY_SECRET=change-me-to-a-local-random-secret

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com
SALARY_SEARCH_TIMEOUT_MS=8000

RUSTFS_ENDPOINT=http://xiaosongshu-rustfs:9000
RUSTFS_REGION=us-east-1
RUSTFS_FORCE_PATH_STYLE=true

KKFILEVIEW_IMAGE=keking/kkfileview:4.4.0

WHISPER_MODEL_ID=Xenova/whisper-tiny
WHISPER_MODEL_DIR=models
WHISPER_LANGUAGE=zh
WHISPER_CHUNK_LENGTH=20
WHISPER_STRIDE_LENGTH=4
HF_ENDPOINT=https://hf-mirror.com
