PORT=5175
BODY_LIMIT_BYTES=20971520
DEFAULT_CURRENT_USER=本地用户

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com
SALARY_SEARCH_TIMEOUT_MS=8000
# BOSS 薪酬样本优先通过 eatmoreduck/boss-zhipin-scraper 抓取；先执行 pnpm download:boss-scraper，再执行 pnpm boss-scraper:setup-chrome 登录专用 Chrome
BOSS_SCRAPER_ENABLED=true
BOSS_SCRAPER_DIR=tools/boss-zhipin-scraper
BOSS_SCRAPER_PYTHON=.venv/bin/python
BOSS_SCRAPER_OUTPUT_DIR=data/salary-scraper
BOSS_SCRAPER_CDP_PORT=9222
BOSS_SCRAPER_PAGES=1
BOSS_SCRAPER_TIMEOUT_MS=180000

RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_REGION=cn-east-1
RUSTFS_ACCESS_KEY_ID=change-me-rustfs-access-key
RUSTFS_SECRET_ACCESS_KEY=change-me-rustfs-secret-key
RUSTFS_BUCKET=xiaosongshu
RUSTFS_FORCE_PATH_STYLE=true
UPLOAD_MAX_FILE_SIZE_MB=3000
# FILE_PROXY_SECRET 用来给文件预览/下载的临时访问链接签名 可通过 openssl rand -base64 32 生成一个随机字符串
FILE_PROXY_SECRET=change-me-to-a-local-random-secret

WHISPER_MODEL_ID=Xenova/whisper-tiny
WHISPER_MODEL_DIR=models
WHISPER_LANGUAGE=zh
WHISPER_CHUNK_LENGTH=20
WHISPER_STRIDE_LENGTH=4
# 下载语音转写模型时使用的 Hugging Face 镜像；服务运行时只读取本地 models 目录
HF_ENDPOINT=https://hf-mirror.com

# Optional: used when an external kkFileView service requests files through this backend.
KKFILE_OA_BASE_URL=
