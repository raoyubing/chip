{
  "name": "@xiaosongshu/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "download:whisper-model": "tsx src/scripts/download-whisper-model.ts",
    "download:boss-scraper": "bash scripts/install-boss-scraper.sh",
    "boss-scraper:check": "bash scripts/run-boss-scraper.sh --check",
    "boss-scraper:setup-chrome": "bash scripts/run-boss-scraper.sh --setup-chrome",
    "demo:load": "tsx src/scripts/load-demo-data.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1052.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/sensible": "^5.6.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@huggingface/transformers": "^4.2.0",
    "@xiaosongshu/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "fastify": "^4.28.1",
    "mammoth": "^1.12.0",
    "nanoid": "^5.0.7",
    "pdf-parse": "^1.1.1",
    "sql.js": "^1.10.3",
    "tesseract.js": "^7.0.0",
    "wavefile": "^11.0.0",
    "word-extractor": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "@types/sql.js": "^1.4.9",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
